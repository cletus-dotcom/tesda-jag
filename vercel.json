{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{public/**,venv/**,.venv/**,uploads/**,**/__pycache__/**,**/*.pyc,*.xlsx,supabase/**,.git/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
