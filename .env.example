# --- Local development (PostgreSQL) ---
DB_USER=postgres
DB_PASS=password
DB_IP=127.0.0.1
DB_PORT=5432
DB_NAME=tesda_jag

# --- Supabase (production) ---
# Use the Transaction pooler URI for Vercel/serverless (port 6543).
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=
# SUPABASE_DATABASE_URL=

# --- Flask / Vercel ---
SECRET_KEY=change-this-to-a-long-random-secret
FLASK_ENV=production
PORT=8030
# DB bootstrap is skipped automatically on Vercel (apply schema via Supabase migrations).
# For local dev, bootstrap runs on startup unless you set:
# SKIP_DB_BOOTSTRAP=true

# --- Google Drive (RMT PDF uploads; required on Vercel — no local disk) ---
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Paste full service-account JSON on Vercel (single line or minified):
# GOOGLE_SERVICE_ACCOUNT_JSON=
